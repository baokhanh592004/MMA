<%- include('../partials/header') %>

<div class="container mt-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-question-circle"></i> Questions</h2>
    <a href="/questions/new" class="btn btn-primary">
      <i class="bi bi-plus-circle"></i> Add Question
    </a>
  </div>

  <% if (questions && questions.length > 0) { %>
    <div class="table-responsive">
      <table class="table table-striped table-hover">
        <thead class="table-dark">
          <tr>
            <th>#</th>
            <th>Question Text</th>
            <th>Keywords</th>
            <th>Options Count</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% questions.forEach((q, index) => { %>
            <tr>
              <td><%= index + 1 %></td>
              <td><%= q.text %></td>
              <td>
                <% q.keyword.forEach(k => { %>
                  <span class="badge bg-info"><%= k %></span>
                <% }) %>
              </td>
              <td><%= q.options.length %></td>
              <td>
                <a href="/questions/<%= q._id %>" class="btn btn-sm btn-info btn-action">
                  <i class="bi bi-eye"></i>
                </a>
                <a href="/questions/<%= q._id %>/edit" class="btn btn-sm btn-warning btn-action">
                  <i class="bi bi-pencil"></i>
                </a>
                <form action="/questions/<%= q._id %>?_method=DELETE" method="POST" style="display:inline;">
                  <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Are you sure?')">
                    <i class="bi bi-trash"></i>
                  </button>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } else { %>
    <div class="alert alert-info">
      <i class="bi bi-info-circle"></i> No questions found. <a href="/questions/new">Create one</a>
    </div>
  <% } %>
</div>

<%- include('../partials/footer') %>
