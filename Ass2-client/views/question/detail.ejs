<%- include('../partials/header') %>

<div class="container mt-4">
  <div class="card">
    <div class="card-header bg-primary text-white">
      <h4><i class="bi bi-question-circle"></i> Question Detail</h4>
    </div>
    <div class="card-body">
      <h5 class="card-title"><%= q.text %></h5>
      
      <h6 class="mt-4">Options:</h6>
      <ul class="list-group mb-3">
        <% q.options.forEach((opt, index) => { %>
          <li class="list-group-item d-flex justify-content-between align-items-center">
            <%= opt %>
            <% if (index === q.correctAnswerIndex) { %>
              <span class="badge bg-success"><i class="bi bi-check-circle"></i> Correct</span>
            <% } %>
          </li>
        <% }) %>
      </ul>

      <h6>Keywords:</h6>
      <p>
        <% q.keyword.forEach(k => { %>
          <span class="badge bg-info me-1"><%= k %></span>
        <% }) %>
      </p>

      <div class="mt-4">
        <a href="/questions/<%= q._id %>/edit" class="btn btn-warning">
          <i class="bi bi-pencil"></i> Edit
        </a>
        <form action="/questions/<%= q._id %>?_method=DELETE" method="POST" style="display:inline;">
          <button type="submit" class="btn btn-danger" onclick="return confirm('Are you sure?')">
            <i class="bi bi-trash"></i> Delete
          </button>
        </form>
        <a href="/questions" class="btn btn-secondary">
          <i class="bi bi-arrow-left"></i> Back
        </a>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
