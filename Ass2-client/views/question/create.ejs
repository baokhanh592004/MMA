<%- include('../partials/header') %>

<div class="container mt-4">
  <div class="card">
    <div class="card-header bg-primary text-white">
      <h4><i class="bi bi-plus-circle"></i> Create Question</h4>
    </div>
    <div class="card-body">
      <form action="/questions" method="POST">
        <div class="mb-3">
          <label class="form-label">Question Text</label>
          <input type="text" name="text" class="form-control" placeholder="Enter question text" required>
        </div>

        <div class="mb-3">
          <label class="form-label">Options (comma separated)</label>
          <input type="text" name="options" class="form-control" placeholder="Paris, London, Berlin, Madrid" required>
          <small class="text-muted">Separate each option with a comma</small>
        </div>

        <div class="mb-3">
          <label class="form-label">Keywords (comma separated)</label>
          <input type="text" name="keyword" class="form-control" placeholder="keyword1, keyword2" required>
        </div>

        <div class="mb-3">
          <label class="form-label">Correct Answer Index (0-based)</label>
          <input type="number" name="correctAnswerIndex" class="form-control" min="0" value="0" required>
          <small class="text-muted">Index starts from 0 (first option = 0)</small>
        </div>

        <button type="submit" class="btn btn-primary">
          <i class="bi bi-check-circle"></i> Create
        </button>
        <a href="/questions" class="btn btn-secondary">
          <i class="bi bi-x-circle"></i> Cancel
        </a>
      </form>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
